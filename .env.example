# Supabase project — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Server-only key used by the daily-digest / reminder scripts (Project Settings → API → service_role).
# NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI features (natural-language capture, auto-prioritize, plan my day).
# Server-only — never expose to the browser. Leave unset to disable AI features gracefully.
ANTHROPIC_API_KEY=your-anthropic-api-key
# Optional model overrides. Defaults: a balanced model for reasoning, a fast/cheap model for parsing.
# ANTHROPIC_MODEL=claude-sonnet-5
# ANTHROPIC_MODEL_FAST=claude-haiku-4-5

# App URL used for Stripe redirect/return URLs when the request origin is unavailable.
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Billing — Stripe (web). Server-only. Leave unset to disable billing gracefully.
STRIPE_SECRET_KEY=sk_live_or_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_TEAM=price_...

# Billing — RevenueCat (iOS/Android IAP). Shared secret sent as the webhook Authorization: Bearer.
REVENUECAT_WEBHOOK_SECRET=your-revenuecat-webhook-secret
